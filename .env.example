# Core
FLASK_ENV=production
SECRET_KEY=change-me-to-a-64-char-hex-string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gym_saas
PUBLIC_BASE_URL=http://localhost:5000

# Sessions & security
SESSION_COOKIE_SECURE=true

# Reminders
ENABLE_SCHEDULER=false
REMINDER_DAYS_BEFORE=7,3,1,0
REMINDER_JOB_MINUTES=60

# Storage
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=5242880
STORAGE_BACKEND=local
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION=ap-south-1
AWS_S3_PUBLIC_BASE_URL=

# WhatsApp Cloud API
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0

# Redis (required in production for rate limiting)
REDIS_URL=redis://localhost:6379/0

# Error tracking
SENTRY_DSN=

# Admin bootstrap
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=
DEMO_OWNER_PASSWORD=
